<% errors = book_list.errors.any? || book_list.book.errors.any? %>

<% if errors %>
  <div role="alert" class="alert alert-error mb-4">
    <ul class="list-disc list-inside text-sm">
      <% (book_list.errors.full_messages + book_list.book.errors.full_messages).each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [klub, book_list] do |form| %>
  <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-3">Book details</p>

  <div class="mb-3">
    <%= form.label :title, "Title", class: "block text-sm font-medium mb-1" %>
    <%= form.text_field :title, value: book_list.book&.title, required: true,
          placeholder: "e.g. Dune", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-3">
    <%= form.label :author, "Author", class: "block text-sm font-medium mb-1" %>
    <%= form.text_field :author, value: book_list.book&.author, required: true,
          placeholder: "e.g. Frank Herbert", class: "input input-bordered w-full" %>
  </div>

  <div class="mb-3">
    <%= form.label :goodreads_url, "Goodreads URL", class: "block text-sm font-medium mb-1" %>
    <%= form.url_field :goodreads_url, value: book_list.book&.goodreads_url,
          placeholder: "https://www.goodreads.com/book/show/...",
          class: "input input-bordered w-full" %>
  </div>

  <div class="mb-6">
    <%= form.label :description, "Description", class: "block text-sm font-medium mb-1" %>
    <%= form.text_area :description, value: book_list.book&.description, rows: 3,
          placeholder: "Optional blurb", class: "textarea textarea-bordered w-full" %>
  </div>

  <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-3">Schedule</p>

  <div class="flex gap-3 mb-6">
    <div class="flex-1">
      <%= form.label :month, "Month", class: "block text-sm font-medium mb-1" %>
      <%= form.select :month,
            BookList::MONTHS.each_with_index.map { |name, i| [name, i + 1] },
            { selected: book_list.month || Date.today.month },
            required: true, class: "select select-bordered w-full" %>
    </div>
    <div class="w-28">
      <%= form.label :year, "Year", class: "block text-sm font-medium mb-1" %>
      <%= form.select :year,
            (Date.today.year - 2..Date.today.year + 2).to_a,
            { selected: book_list.year || Date.today.year },
            required: true, class: "select select-bordered w-full" %>
    </div>
  </div>

  <%= form.submit button_label, class: "btn btn-primary w-full" %>
<% end %>

<p class="text-center text-sm mt-4">
  <%= link_to "← Back to #{klub.name}", klub_path(klub), class: "link link-primary" %>
</p>
