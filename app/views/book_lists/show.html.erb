<div class="space-y-8">
  <div>
    <%= link_to "← #{@klub.name}", klub_path(@klub), class: "link link-primary text-sm" %>
  </div>

  <%# Book header %>
  <div class="flex flex-col sm:flex-row gap-6">
    <div class="flex-1">
      <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50"><%= @book_list.period %></p>
      <h2 class="text-2xl font-bold mt-1"><%= @book_list.book.title %></h2>
      <p class="text-base-content/60 mt-1">by <%= @book_list.book.author %></p>
      <% if @book_list.book.goodreads_url.present? %>
        <p class="mt-2">
          <%= link_to "View on Goodreads →", @book_list.book.goodreads_url,
                target: "_blank", rel: "noopener", class: "link link-primary text-sm" %>
        </p>
      <% end %>
      <% if @book_list.book.description.present? %>
        <p class="text-sm text-base-content/60 mt-3 max-w-lg"><%= @book_list.book.description %></p>
      <% end %>
    </div>

    <%# Score summary %>
    <div class="bg-base-100 rounded-xl border border-base-300 shadow-sm flex-shrink-0 w-36 flex flex-col items-center justify-center px-4 py-6">
      <% avg = @book_list.average_score %>
      <% if avg %>
        <span class="text-4xl font-bold text-primary"><%= avg %></span>
        <span class="text-xs text-base-content/50 mt-1">out of 5</span>
        <span class="text-xs text-base-content/40 mt-1"><%= @ratings.count %> <%= "rating".pluralize(@ratings.count) %></span>
      <% else %>
        <span class="text-sm text-base-content/40">No ratings yet</span>
      <% end %>
    </div>
  </div>

  <%# Ratings list %>
  <section>
    <h3 class="text-base font-semibold mb-3">Ratings</h3>
    <% if @ratings.any? %>
      <ul class="space-y-1">
        <% @ratings.each do |r| %>
          <li class="flex items-center gap-3 py-2 border-b border-base-200">
            <span class="flex-1 text-sm"><%= r.user.full_name %></span>
            <span class="badge badge-primary badge-outline badge-sm"><%= r.score %> / 5</span>
            <% if r.user == Current.session.user %>
              <%= button_to klub_book_list_rating_path(@klub, @book_list),
                    method: :delete,
                    class: "btn btn-ghost btn-xs btn-square text-error", title: "Remove rating" do %>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5"><path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd"/></svg>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-base-content/50">No ratings yet — be the first!</p>
    <% end %>
  </section>

  <%# Rating form %>
  <% if @klub.member?(Current.session.user) %>
    <section>
      <h3 class="text-base font-semibold mb-3">
        <%= @my_rating.persisted? ? "Update your rating" : "Rate this book" %>
      </h3>

      <%= form_with url: klub_book_list_rating_path(@klub, @book_list) do |form| %>
        <div class="flex items-center gap-4 flex-wrap">
          <div class="flex gap-2">
            <% (1..5).each do |n| %>
              <label class="cursor-pointer">
                <input type="radio" name="rating[score]" value="<%= n %>"
                       class="sr-only peer"
                       <%= "checked" if @my_rating.score == n %>>
                <span class="w-10 h-10 flex items-center justify-center rounded-lg border-2 border-base-300 font-semibold text-sm text-base-content/40 cursor-pointer transition-all select-none hover:border-primary hover:text-primary hover:bg-primary/10 peer-checked:bg-primary peer-checked:border-primary peer-checked:text-primary-content peer-checked:scale-110 peer-checked:shadow-md peer-checked:font-bold">
                  <%= n %>
                </span>
              </label>
            <% end %>
          </div>
          <%= form.submit @my_rating.persisted? ? "Update" : "Submit Rating",
                class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
