<div class="max-w-lg mx-auto">
  <div class="mb-4">
    <%= link_to "← Back to dashboard", root_path, class: "link link-primary text-sm" %>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body gap-4">
      <h2 class="card-title text-xl">Create a Klub</h2>

      <% if @klub.errors.any? %>
        <div role="alert" class="alert alert-error">
          <ul class="list-disc list-inside text-sm">
            <% @klub.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @klub do |form| %>
        <div class="mb-3">
          <%= form.label :name, "Klub name", class: "block text-sm font-medium mb-1" %>
          <%= form.text_field :name, placeholder: "e.g. Booh", required: true,
                class: "input input-bordered w-full" %>
        </div>

        <div class="mb-3">
          <%= form.label :activity_type, "Type", class: "block text-sm font-medium mb-1" %>
          <%= form.select :activity_type,
                Klub::ACTIVITY_TYPES.map { |t| [t.capitalize, t] },
                { prompt: "Choose a type" },
                required: true, class: "select select-bordered w-full" %>
        </div>

        <div class="mb-5">
          <%= form.label :description, "Description", class: "block text-sm font-medium mb-1" %>
          <%= form.text_area :description,
                placeholder: "What's this klub about?", rows: 3,
                class: "textarea textarea-bordered w-full" %>
        </div>

        <%= form.submit "Create Klub", class: "btn btn-primary w-full" %>
      <% end %>
    </div>
  </div>
</div>
