<div class="auth-container">
  <h2 class="auth-title">Create a Klub</h2>

  <% if @klub.errors.any? %>
    <div class="flash flash-alert">
      <% @klub.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @klub, class: "auth-form" do |form| %>
    <div class="form-group">
      <%= form.label :name, "Klub name" %>
      <%= form.text_field :name, placeholder: "e.g. Booh", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :activity_type, "Type" %>
      <%= form.select :activity_type, Klub::ACTIVITY_TYPES.map { |t| [t.capitalize, t] },
            { prompt: "Choose a type" }, required: true,
            style: "width:100%;padding:10px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:1rem;" %>
    </div>

    <div class="form-group">
      <%= form.label :description, "Description" %>
      <%= form.text_area :description, placeholder: "What's this klub about?", rows: 3,
            style: "width:100%;padding:10px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:1rem;" %>
    </div>

    <%= form.submit "Create Klub", class: "btn-primary" %>
  <% end %>

  <p class="auth-link"><%= link_to "← Back to dashboard", root_path %></p>
</div>
