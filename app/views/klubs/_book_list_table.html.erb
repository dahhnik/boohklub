<div class="overflow-x-auto">
  <table class="table table-sm">
    <thead>
      <tr class="text-base-content/50 text-xs uppercase tracking-wider">
        <th>Month</th>
        <th>Title</th>
        <th>Author</th>
        <% if show_scores %><th>Score</th><% end %>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% book_lists.each do |entry| %>
        <tr class="hover">
          <td class="whitespace-nowrap text-sm text-base-content/60"><%= entry.period %></td>
          <td class="font-medium">
            <%= link_to entry.book.title, klub_book_list_path(klub, entry),
                  class: "hover:text-primary transition-colors" %>
          </td>
          <td class="text-sm text-base-content/60"><%= entry.book.author %></td>
          <% if show_scores %>
            <td>
              <% avg = entry.average_score %>
              <% if avg %>
                <span class="badge badge-primary badge-outline badge-sm"><%= avg %> / 5</span>
              <% else %>
                <span class="text-base-content/30 text-sm">—</span>
              <% end %>
            </td>
          <% end %>
          <td class="text-right whitespace-nowrap">
            <% if klub.member?(Current.session.user) %>
              <%= link_to "Edit", edit_klub_book_list_path(klub, entry), class: "btn btn-ghost btn-xs" %>
              <%= button_to "Remove", klub_book_list_path(klub, entry), method: :delete,
                    class: "btn btn-ghost btn-xs text-error",
                    data: { confirm: "Remove #{entry.book.title} from the list?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
