<div class="space-y-8">
  <%# Klub header %>
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <span class="badge badge-outline"><%= @klub.activity_type %></span>
      <h2 class="text-2xl font-bold mt-2"><%= @klub.name %></h2>
      <p class="text-base-content/60 mt-1 max-w-lg">
        <%= @klub.description.presence || "No description yet." %>
      </p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <% if @klub.member?(Current.session.user) %>
        <%= link_to "Add Book", new_klub_book_list_path(@klub), class: "btn btn-primary btn-sm" %>
        <%= button_to "Leave Klub",
              klub_membership_path(@klub, @klub.memberships.find_by(user: Current.session.user)),
              method: :delete, class: "btn btn-ghost btn-sm",
              data: { confirm: "Leave #{@klub.name}?" } %>
      <% else %>
        <%= button_to "Join Klub", klub_memberships_path(@klub), class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>
  </div>

  <%# Reading Schedule %>
  <section>
    <h3 class="text-lg font-semibold mb-4">Reading Schedule</h3>

    <% scheduled = @klub.book_lists.scheduled.chronological.includes(:book) %>
    <% read      = @klub.book_lists.read.reverse_chrono.includes(:book) %>

    <% if scheduled.any? %>
      <div class="card bg-base-100 shadow-sm border border-base-300 overflow-hidden">
        <div class="px-5 pt-4 pb-1">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-base-content/50">Coming up</h4>
        </div>
        <%= render "book_list_table", book_lists: scheduled, klub: @klub, show_scores: false %>
      </div>
    <% end %>

    <% if read.any? %>
      <div class="card bg-base-100 shadow-sm border border-base-300 overflow-hidden <%= 'mt-4' if scheduled.any? %>">
        <div class="px-5 pt-4 pb-1">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-base-content/50">Books we've read</h4>
        </div>
        <%= render "book_list_table", book_lists: read, klub: @klub, show_scores: true %>
      </div>
    <% end %>

    <% if scheduled.empty? && read.empty? %>
      <div class="text-center py-10 text-base-content/50">
        <p>No books on the list yet.</p>
        <% if @klub.member?(Current.session.user) %>
          <%= link_to "Add the first one →", new_klub_book_list_path(@klub), class: "btn btn-primary btn-sm mt-3" %>
        <% end %>
      </div>
    <% end %>
  </section>

  <%# Members %>
  <section>
    <h3 class="text-lg font-semibold mb-3">Members (<%= @members.count %>)</h3>
    <ul class="space-y-1">
      <% @members.each do |membership| %>
        <li class="flex items-center gap-3 py-2 border-b border-base-200">
          <span class="w-8 h-8 rounded-full bg-base-300 flex items-center justify-center text-xs font-bold flex-shrink-0">
            <%= membership.user.full_name.split.map { |n| n[0] }.first(2).join %>
          </span>
          <span class="flex-1 text-sm"><%= membership.user.full_name %></span>
          <span class="badge badge-sm <%= membership.role == 'admin' ? 'badge-warning' : 'badge-ghost' %>">
            <%= membership.role %>
          </span>
        </li>
      <% end %>
    </ul>
  </section>
</div>
