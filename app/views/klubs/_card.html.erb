<div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow border border-base-300">
  <div class="card-body p-5 gap-2">
    <div>
      <span class="badge badge-outline badge-sm"><%= klub.activity_type %></span>
      <h3 class="card-title text-base mt-2">
        <%= link_to klub.name, klub_path(klub), class: "hover:text-primary transition-colors" %>
      </h3>
      <p class="text-sm text-base-content/60 mt-1">
        <%= klub.description.presence || "No description yet." %>
      </p>
    </div>
    <p class="text-xs text-base-content/40">
      <%= klub.users.count %> <%= "member".pluralize(klub.users.count) %>
    </p>
    <div class="card-actions mt-1">
      <% if joined %>
        <%= link_to "View", klub_path(klub), class: "btn btn-primary btn-sm" %>
        <%= button_to "Leave",
              klub_membership_path(klub, klub.memberships.find_by(user: Current.session.user)),
              method: :delete, class: "btn btn-ghost btn-sm",
              data: { confirm: "Leave #{klub.name}?" } %>
      <% else %>
        <%= button_to "Join", klub_memberships_path(klub), class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>
  </div>
</div>
