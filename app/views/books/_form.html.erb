<% if book.errors.any? %>
  <div role="alert" class="alert alert-error mb-4">
    <ul class="list-disc list-inside text-sm">
      <% book.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: book do |form| %>
  <div class="mb-3">
    <%= form.label :title, "Title", class: "block text-sm font-medium mb-1" %>
    <%= form.text_field :title, required: true, placeholder: "e.g. Dune",
          class: "input input-bordered w-full" %>
  </div>

  <div class="mb-3">
    <%= form.label :author, "Author", class: "block text-sm font-medium mb-1" %>
    <%= form.text_field :author, required: true, placeholder: "e.g. Frank Herbert",
          class: "input input-bordered w-full" %>
  </div>

  <div class="mb-3">
    <%= form.label :goodreads_url, "Goodreads URL", class: "block text-sm font-medium mb-1" %>
    <%= form.url_field :goodreads_url,
          placeholder: "https://www.goodreads.com/book/show/...",
          class: "input input-bordered w-full" %>
  </div>

  <div class="mb-5">
    <%= form.label :description, "Description", class: "block text-sm font-medium mb-1" %>
    <%= form.text_area :description, rows: 3, class: "textarea textarea-bordered w-full" %>
  </div>

  <%= form.submit button_label, class: "btn btn-primary w-full" %>
<% end %>
