<% if book.errors.any? %>
  <div class="flash flash-alert">
    <% book.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
  </div>
<% end %>

<%= form_with model: book, class: "auth-form" do |form| %>
  <div class="form-group">
    <%= form.label :title, "Title" %>
    <%= form.text_field :title, required: true, placeholder: "e.g. Dune" %>
  </div>
  <div class="form-group">
    <%= form.label :author, "Author" %>
    <%= form.text_field :author, required: true, placeholder: "e.g. Frank Herbert" %>
  </div>
  <div class="form-group">
    <%= form.label :goodreads_url, "Goodreads URL" %>
    <%= form.url_field :goodreads_url, placeholder: "https://www.goodreads.com/book/show/..." %>
  </div>
  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 3 %>
  </div>
  <%= form.submit button_label, class: "btn-primary" %>
<% end %>
