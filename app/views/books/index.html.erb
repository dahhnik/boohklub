<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h2 class="text-xl font-bold">Book Catalog</h2>
    <%= link_to "Add Book", new_book_path, class: "btn btn-primary btn-sm" %>
  </div>

  <% if @books.any? %>
    <div class="overflow-x-auto">
      <table class="table table-sm">
        <thead>
          <tr class="text-base-content/50 text-xs uppercase tracking-wider">
            <th>Title</th>
            <th>Author</th>
            <th>Link</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr class="hover">
              <td class="font-medium"><%= book.title %></td>
              <td class="text-sm text-base-content/60"><%= book.author %></td>
              <td>
                <% if book.goodreads_url.present? %>
                  <%= link_to "Goodreads →", book.goodreads_url,
                        target: "_blank", rel: "noopener", class: "link link-primary text-sm" %>
                <% end %>
              </td>
              <td class="text-right whitespace-nowrap">
                <%= link_to "Edit", edit_book_path(book), class: "btn btn-ghost btn-xs" %>
                <%= button_to "Delete", book_path(book), method: :delete,
                      class: "btn btn-ghost btn-xs text-error",
                      data: { confirm: "Delete #{book.title}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-base-content/50">No books in the catalog yet.</p>
  <% end %>
</div>
