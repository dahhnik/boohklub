<div class="dashboard">
  <header class="dashboard-header">
    <h1>Boohklub</h1>
    <div class="header-actions">
      <span class="user-name"><%= Current.session.user.full_name %></span>
      <%= button_to "Sign out", session_path, method: :delete, class: "btn-secondary" %>
    </div>
  </header>

  <main class="dashboard-main">
    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <div class="dashboard-section">
      <div class="section-header">
        <h2>My Klubs</h2>
        <%= link_to "Create a Klub", new_klub_path, class: "btn-primary btn-sm" %>
      </div>

      <% if Current.session.user.klubs.any? %>
        <div class="klub-grid">
          <% Current.session.user.klubs.each do |klub| %>
            <%= render "klubs/card", klub: klub, joined: true %>
          <% end %>
        </div>
      <% else %>
        <p class="empty-state">You haven't joined any klubs yet.</p>
      <% end %>
    </div>

    <div class="dashboard-section">
      <div class="section-header">
        <h2>Discover Klubs</h2>
      </div>

      <% other_klubs = Klub.where.not(id: Current.session.user.klubs) %>
      <% if other_klubs.any? %>
        <div class="klub-grid">
          <% other_klubs.each do |klub| %>
            <%= render "klubs/card", klub: klub, joined: false %>
          <% end %>
        </div>
      <% else %>
        <p class="empty-state">No other klubs to join right now.</p>
      <% end %>
    </div>
  </main>
</div>
