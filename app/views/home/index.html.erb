<div class="space-y-10">
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold">My Klubs</h2>
      <%= link_to "Create a Klub", new_klub_path, class: "btn btn-primary btn-sm" %>
    </div>

    <% if Current.session.user.klubs.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% Current.session.user.klubs.each do |klub| %>
          <%= render "klubs/card", klub: klub, joined: true %>
        <% end %>
      </div>
    <% else %>
      <div class="card bg-base-100 border border-base-300">
        <div class="card-body text-center py-10">
          <p class="text-base-content/50">You haven't joined any klubs yet.</p>
          <%= link_to "Create the first one →", new_klub_path, class: "btn btn-primary btn-sm mt-3" %>
        </div>
      </div>
    <% end %>
  </section>

  <div class="divider"></div>

  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold">Discover Klubs</h2>
    </div>

    <% other_klubs = Klub.where.not(id: Current.session.user.klubs) %>
    <% if other_klubs.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% other_klubs.each do |klub| %>
          <%= render "klubs/card", klub: klub, joined: false %>
        <% end %>
      </div>
    <% else %>
      <p class="text-base-content/50 text-sm">No other klubs to discover right now.</p>
    <% end %>
  </section>
</div>
